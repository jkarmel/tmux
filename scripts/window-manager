#!/usr/bin/env python3
"""Custom tmux window manager with tree view and pane preview.

Shows sessions with windows nested underneath. Sessions are non-selectable
headers; j/k navigates only between windows. Preview panel on the right
shows the selected window's pane content with ANSI colors preserved.
Press / for fzf fuzzy search.

Pass --session for a session-focused view that shows one session at a time
with h/l keys to cycle between sessions.

Pass --sessions for a session list view that shows all sessions with their
working directories on the left and a compact window list preview on the right.
"""

from __future__ import annotations

import curses
import locale
import os
import re
import shlex
import shutil
import subprocess
import sys
import tempfile
import unicodedata
from dataclasses import dataclass
from pathlib import Path


# ── Constants ────────────────────────────────────────────────────

DEFAULT_PATH_SEGMENTS = [
    "/opt/homebrew/bin",
    "/usr/local/bin",
    "/usr/bin",
    "/bin",
    "/usr/sbin",
    "/sbin",
]

# Match SGR sequences with ; or : separators (tmux uses : for ISO 8613-6)
ANSI_SGR_RE = re.compile(r"\033\[([0-9;:]*)m")
# Match any escape sequence (SGR, cursor movement, etc.)
ANSI_ANY_RE = re.compile(r"\033(?:\[[0-9;:]*[A-Za-z]|\][^\033]*(?:\033\\|\007))")
# Match trailing timestamp in worktree branch names: -YYYYMMDD_HHMMSS
WORKTREE_TS_RE = re.compile(r"-\d{8}_\d{6}$")


def _char_width(ch: str) -> int:
    """Approximate terminal display width of a character."""
    cp = ord(ch)
    if cp < 0x300:
        return 1
    eaw = unicodedata.east_asian_width(ch)
    if eaw in ("W", "F"):
        return 2
    # Emoji blocks that render as 2 cells in modern terminals
    if 0x1F000 <= cp <= 0x1FFFF or 0x2600 <= cp <= 0x27BF:
        return 2
    return 1


def _truncate_ansi(text: str, max_cols: int) -> str:
    """Truncate an ANSI-colored string to max_cols display columns.

    Preserves escape sequences (zero display width) and expands tabs.
    Appends a reset so colors don't bleed.
    """
    result: list[str] = []
    col = 0
    pos = 0
    while pos < len(text) and col < max_cols:
        # Pass through any escape sequence (zero width)
        m = ANSI_ANY_RE.match(text, pos)
        if m:
            result.append(m.group(0))
            pos = m.end()
            continue
        # Bare ESC that didn't match a known sequence — skip to end of it
        if text[pos] == "\033":
            end = pos + 1
            while end < len(text) and text[end] not in "ABCDEFGHJKSTfmnsulh":
                end += 1
            pos = end + 1 if end < len(text) else end
            continue
        ch = text[pos]
        pos += 1
        if ch == "\t":
            spaces = min(8 - (col % 8), max_cols - col)
            result.append(" " * spaces)
            col += spaces
        else:
            cw = _char_width(ch)
            if col + cw > max_cols:
                break
            result.append(ch)
            col += cw
    result.append("\033[0m")
    return "".join(result)


# ── Utilities ────────────────────────────────────────────────────


def ensure_reasonable_path() -> None:
    current = os.environ.get("PATH", "")
    parts = [p for p in current.split(":") if p]
    for seg in DEFAULT_PATH_SEGMENTS:
        if seg not in parts:
            parts.append(seg)
    os.environ["PATH"] = ":".join(parts)


# ── Data Model ───────────────────────────────────────────────────


@dataclass
class Window:
    session: str
    index: int
    name: str
    pane_id: str
    ai_status: str
    is_current: bool


@dataclass
class TreeItem:
    kind: str  # "session" or "window"
    label: str
    window: Window | None = None
    hotkey: str | None = None


@dataclass
class Session:
    name: str
    path: str           # working directory from tmux session_path
    windows: list[Window]
    is_current: bool


@dataclass
class Worktree:
    path: Path            # worktree directory
    repo_root: Path       # main repo root
    branch: str           # e.g. "ai/easy-claw-20260221_165351"
    head: str             # HEAD SHA
    display_name: str     # "easy-claw" (no ai/ prefix, no timestamp)
    last_commit_date: str # "3 hours ago" via git log --format=%cr
    status: str           # "clean" | "dirty" | "prunable"
    merged: bool          # all commits reachable from main?


# ── tmux helpers ─────────────────────────────────────────────────


def get_current_target() -> str:
    result = subprocess.run(
        ["tmux", "display-message", "-p", "#{session_name}:#{window_index}"],
        capture_output=True, text=True,
    )
    return result.stdout.strip() if result.returncode == 0 else ""


def get_windows() -> dict[str, list[Window]]:
    """Return windows grouped by session name (insertion-ordered)."""
    current = get_current_target()
    result = subprocess.run(
        [
            "tmux", "list-windows", "-a", "-F",
            "#{session_name}\t#{window_index}\t#{window_name}\t#{pane_id}\t#{@ai_status}",
        ],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return {}

    sessions: dict[str, list[Window]] = {}
    for line in result.stdout.strip().split("\n"):
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        session, idx, name, pane_id = parts[0], parts[1], parts[2], parts[3]
        ai_status = parts[4] if len(parts) > 4 else ""
        target = f"{session}:{idx}"
        w = Window(
            session=session,
            index=int(idx),
            name=name,
            pane_id=pane_id,
            ai_status=ai_status,
            is_current=(target == current),
        )
        sessions.setdefault(session, []).append(w)
    return sessions


def get_sessions() -> list[Session]:
    """Return all sessions with their paths and windows."""
    current_target = get_current_target()
    cur_session = current_target.split(":")[0] if ":" in current_target else ""

    # Get session paths
    result = subprocess.run(
        ["tmux", "list-sessions", "-F", "#{session_name}\t#{session_path}"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return []

    session_paths: dict[str, str] = {}
    for line in result.stdout.strip().split("\n"):
        if not line:
            continue
        parts = line.split("\t", 1)
        if len(parts) == 2:
            session_paths[parts[0]] = parts[1]

    windows_by_session = get_windows()

    sessions: list[Session] = []
    for name, windows in windows_by_session.items():
        path = session_paths.get(name, "")
        sessions.append(Session(
            name=name,
            path=path,
            windows=windows,
            is_current=(name == cur_session),
        ))
    return sessions


def get_worktrees() -> list[Worktree]:
    """Discover all git worktrees across tmux session paths."""
    # 1. Discover repo roots from tmux sessions
    result = subprocess.run(
        ["tmux", "list-sessions", "-F", "#{session_path}"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return []

    session_paths = set(result.stdout.strip().splitlines())
    repo_roots: set[str] = set()
    for sp in session_paths:
        if not sp:
            continue
        r = subprocess.run(
            ["git", "-C", sp, "rev-parse", "--show-toplevel"],
            capture_output=True, text=True,
        )
        if r.returncode == 0 and r.stdout.strip():
            repo_roots.add(r.stdout.strip())

    worktrees: list[Worktree] = []

    for root_str in sorted(repo_roots):
        root = Path(root_str)
        # 2. Parse git worktree list --porcelain
        r = subprocess.run(
            ["git", "-C", root_str, "worktree", "list", "--porcelain"],
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            continue

        # Parse porcelain output: blocks separated by blank lines
        entries: list[dict[str, str]] = []
        current: dict[str, str] = {}
        for line in r.stdout.splitlines():
            if not line.strip():
                if current:
                    entries.append(current)
                    current = {}
            else:
                if line.startswith("worktree "):
                    current["worktree"] = line[9:]
                elif line.startswith("HEAD "):
                    current["HEAD"] = line[5:]
                elif line.startswith("branch "):
                    current["branch"] = line[7:]
                elif line == "prunable":
                    current["prunable"] = "true"
                elif line == "detached":
                    current["detached"] = "true"
        if current:
            entries.append(current)

        # Skip the main worktree (first entry)
        for entry in entries[1:]:
            wt_path_str = entry.get("worktree", "")
            if not wt_path_str:
                continue
            wt_path = Path(wt_path_str)
            head = entry.get("HEAD", "")
            branch = entry.get("branch", "")
            is_prunable = "prunable" in entry

            # Clean branch name
            branch_name = branch.replace("refs/heads/", "") if branch else ""

            # Display name: strip ai/ prefix and timestamp
            display = branch_name
            if display.startswith("ai/"):
                display = display[3:]
            display = WORKTREE_TS_RE.sub("", display)
            if not display:
                display = wt_path.name

            # Last commit date
            if head:
                r2 = subprocess.run(
                    ["git", "-C", root_str, "log", "-1", "--format=%cr", head],
                    capture_output=True, text=True,
                )
                last_commit = r2.stdout.strip() if r2.returncode == 0 else "unknown"
            else:
                last_commit = "unknown"

            # Merged check
            if head:
                r3 = subprocess.run(
                    ["git", "-C", root_str, "merge-base", "--is-ancestor", head, "main"],
                    capture_output=True, text=True,
                )
                merged = r3.returncode == 0
            else:
                merged = False

            # Status
            if is_prunable:
                status = "prunable"
            else:
                r4 = subprocess.run(
                    ["git", "-C", wt_path_str, "status", "--porcelain"],
                    capture_output=True, text=True,
                )
                if r4.returncode == 0 and r4.stdout.strip():
                    status = "dirty"
                else:
                    status = "clean"

            worktrees.append(Worktree(
                path=wt_path,
                repo_root=root,
                branch=branch_name,
                head=head,
                display_name=display,
                last_commit_date=last_commit,
                status=status,
                merged=merged,
            ))

    return worktrees


def is_ai_window(window: Window) -> bool:
    name = window.name.lower()
    return "(claude)" in name or "(codex)" in name


def ai_emoji(window: Window) -> str:
    if not is_ai_window(window):
        return ""
    if window.ai_status == "active":
        return "\u26a1 "  # lightning
    if window.ai_status == "done":
        return "\u2705 "  # check
    return "\U0001f916 "  # robot


def capture_pane(pane_id: str) -> list[str]:
    """Capture visible pane content with ANSI colors, stripping trailing blanks."""
    result = subprocess.run(
        ["tmux", "capture-pane", "-e", "-t", pane_id, "-p"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return ["(unable to capture pane)"]
    content = result.stdout.rstrip("\n").split("\n")
    # Strip trailing blank lines (ignoring escape codes)
    while content and not ANSI_SGR_RE.sub("", content[-1]).strip():
        content.pop()
    return content


def should_bottom_align(window: Window, content: list[str]) -> bool:
    """AI windows always bottom-align. Others bottom-align when the top is
    mostly blank (like a shell with a prompt at the bottom)."""
    if is_ai_window(window):
        return True
    if not content:
        return False
    leading_blank = 0
    for line in content:
        if not ANSI_SGR_RE.sub("", line).strip():
            leading_blank += 1
        else:
            break
    return leading_blank > len(content) * 0.4


def _clean_window_name(name: str) -> str:
    """Strip (claude) and (codex) tags from window name."""
    for tag in ("(claude)", "(codex)"):
        name = name.replace(tag, "")
    return name.strip()


def _abbreviate_path(path: str) -> str:
    """Return just the last folder name for display."""
    return os.path.basename(path) or path


def switch_to_session(session_name: str) -> None:
    """Switch to a session's active window."""
    subprocess.run(["tmux", "switch-client", "-t", session_name], check=False)


def switch_to_window(window: Window) -> None:
    target = f"{window.session}:{window.index}"
    subprocess.run(["tmux", "select-window", "-t", target], check=False)
    subprocess.run(["tmux", "switch-client", "-t", window.session], check=False)


# ── Tree building ────────────────────────────────────────────────


# Hotkey letters — skip j/k (nav), q (quit)
HOTKEY_POOL = "abcdefghilmnoprstuvwxyz"


def build_tree(
    sessions: dict[str, list[Window]],
) -> tuple[list[TreeItem], dict[str, Window]]:
    items: list[TreeItem] = []
    hotkey_map: dict[str, Window] = {}
    hotkey_idx = 0
    for session_name, windows in sessions.items():
        items.append(TreeItem(kind="session", label=session_name))
        for w in windows:
            name = _clean_window_name(w.name)
            emoji = ai_emoji(w).strip()
            suffix = f" {emoji}" if emoji else ""
            label = f"{name}{suffix}"
            hotkey = HOTKEY_POOL[hotkey_idx] if hotkey_idx < len(HOTKEY_POOL) else None
            if hotkey:
                hotkey_map[hotkey] = w
                hotkey_idx += 1
            items.append(TreeItem(kind="window", label=label, window=w, hotkey=hotkey))
    return items, hotkey_map


def build_session_tree(
    windows: list[Window],
) -> tuple[list[TreeItem], dict[str, Window]]:
    """Build tree for a single session (windows only, no session headers)."""
    # Skip h/l (session nav), n (new window) in addition to j/k (nav) and q (quit)
    pool = "abcdefgimoprstuvwxyz"
    items: list[TreeItem] = []
    hotkey_map: dict[str, Window] = {}
    hotkey_idx = 0
    for w in windows:
        name = _clean_window_name(w.name)
        emoji = ai_emoji(w).strip()
        suffix = f" {emoji}" if emoji else ""
        label = f"{name}{suffix}"
        hotkey = pool[hotkey_idx] if hotkey_idx < len(pool) else None
        if hotkey:
            hotkey_map[hotkey] = w
            hotkey_idx += 1
        items.append(TreeItem(kind="window", label=label, window=w, hotkey=hotkey))
    return items, hotkey_map


def selectable_indices(items: list[TreeItem]) -> list[int]:
    return [i for i, item in enumerate(items) if item.kind == "window"]


# ── fzf search ───────────────────────────────────────────────────


def fzf_search(items: list[TreeItem]) -> Window | None:
    windows = [it for it in items if it.kind == "window" and it.window]
    if not windows:
        return None

    # Fields: pane_id \t session:index \t display
    # --with-nth=3 shows only the formatted display
    dim = "\033[2m"
    reset = "\033[0m"
    script = str(Path(__file__).resolve())
    fzf_lines = []
    for it in windows:
        w = it.window
        emoji = ai_emoji(w).strip()  # e.g. "⚡" or ""
        name = _clean_window_name(w.name)
        suffix = f" {emoji}" if emoji else ""
        display = f"{name}{suffix} {dim}{w.session}{reset}"
        fzf_lines.append(f"{w.pane_id}\t{w.session}:{w.index}\t{display}")
    input_text = "\n".join(fzf_lines) + "\n"

    try:
        result = subprocess.run(
            [
                "fzf", "--ansi", "--reverse",
                "--header=Search windows",
                "--delimiter=\t",
                "--with-nth=3",
                "--preview", f"{script} --preview {{1}}",
                "--preview-window=right:60%",
            ],
            input=input_text, capture_output=True, text=True, check=False,
        )
    except FileNotFoundError:
        return None

    if result.returncode != 0 or not result.stdout.strip():
        return None

    parts = result.stdout.strip().split("\t")
    if len(parts) < 2:
        return None
    key = parts[1]  # "session:index"
    for it in windows:
        w = it.window
        if f"{w.session}:{w.index}" == key:
            return w
    return None


# ── View switching ───────────────────────────────────────────────


def _read_alt_key(stdscr) -> str | None:
    """After receiving ESC (27), check if Alt+key follows."""
    stdscr.timeout(0)
    ch = stdscr.getch()
    stdscr.timeout(1000)
    if ch == -1:
        return None
    return chr(ch) if 0x20 <= ch <= 0x7E else None


def _handle_alt_switch(stdscr, alt: str, current: str) -> bool:
    """Switch to another view if alt matches. Returns True if switched."""
    targets = {"e": ui, "s": sessions_ui, "w": session_ui, "r": robots_ui}
    if alt in targets and alt != current:
        targets[alt](stdscr)
        return True
    # Alt+a → exec into ai-session-launch (reuses the same popup)
    if alt == "a":
        curses.endwin()
        script = str(Path.home() / ".tmux" / "scripts" / "ai-session-launch")
        os.execvp("python3", ["python3", script])
    return False


# ── Curses rendering helpers ─────────────────────────────────────


def safe_addstr(win, y: int, x: int, text: str, max_width: int, attr: int = 0) -> None:
    """Render plain text (no ANSI) with exact column control."""
    if max_width <= 0:
        return
    height, width = win.getmaxyx()
    if y < 0 or y >= height or x >= width:
        return
    col = x
    max_col = min(x + max_width, width)
    for ch in text:
        if ch == "\t":
            spaces = 8 - ((col - x) % 8)
            for _ in range(min(spaces, max_col - col)):
                try:
                    win.addch(y, col, " ", attr)
                except curses.error:
                    return
                col += 1
        else:
            cw = _char_width(ch)
            if col + cw > max_col:
                break
            try:
                win.addch(y, col, ch, attr)
            except curses.error:
                return
            col += cw
    # Clear remaining columns
    while col < max_col:
        try:
            win.addch(y, col, " ", attr)
        except curses.error:
            return
        col += 1


def render_preview(window: Window | None, content: list[str],
                   col: int, width: int, rows: int) -> None:
    """Render pane preview with raw ANSI escape codes after curses refresh.

    Bypasses curses color handling entirely so the terminal renders the
    exact escape sequences from capture-pane -e (pixel-perfect colors).
    """
    if width <= 0 or not content or not window:
        return
    if should_bottom_align(window, content):
        visible = content[-rows:]
        start_row = max(0, rows - len(visible))
    else:
        visible = content[:rows]
        start_row = 0
    buf: list[str] = []
    for i, line in enumerate(visible):
        row = start_row + i
        if row >= rows:
            break
        truncated = _truncate_ansi(line, width)
        # ANSI cursor positioning is 1-based
        buf.append(f"\033[{row + 1};{col + 1}H{truncated}")
    buf.append("\033[0m")
    sys.stdout.write("".join(buf))
    sys.stdout.flush()


# ── Kill window helper ────────────────────────────────────────────


def _confirm_kill_window(stdscr, window: Window, help_row: int, width: int) -> bool:
    """Show y/n confirmation and kill a tmux window. Returns True if killed."""
    name = _clean_window_name(window.name)
    prompt = f" Kill window '{name}' ({window.session}:{window.index})? y/n"
    safe_addstr(stdscr, help_row, 0, prompt, width,
                curses.color_pair(4) | curses.A_BOLD)
    stdscr.clrtoeol()
    # Force full redraw — raw ANSI preview writes desync curses positioning
    stdscr.clearok(True)
    stdscr.refresh()
    stdscr.timeout(-1)
    confirm_key = stdscr.getch()
    stdscr.timeout(1000)
    if confirm_key not in (ord("y"), ord("Y")):
        return False
    target = f"{window.session}:{window.index}"
    subprocess.run(
        ["tmux", "kill-window", "-t", target],
        capture_output=True, check=False,
    )
    return True


# ── Main UI ──────────────────────────────────────────────────────


def ui(stdscr) -> None:
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)       # session headers
    curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)  # selected
    curses.init_pair(3, curses.COLOR_WHITE, -1)      # normal window
    curses.init_pair(4, curses.COLOR_YELLOW, -1)     # help bar
    curses.init_pair(5, curses.COLOR_MAGENTA, -1)    # hotkey letter

    sessions = get_windows()
    if not sessions:
        return

    items, hotkey_map = build_tree(sessions)
    sel_indices = selectable_indices(items)
    if not sel_indices:
        return

    # Default to current window
    selected = 0
    for i, idx in enumerate(sel_indices):
        w = items[idx].window
        if w and w.is_current:
            selected = i
            break

    scroll_offset = 0
    last_pane_id: str | None = None
    preview_cache: list[str] = []

    # 1000ms timeout: keys are instant, preview refreshes every ~1s when idle
    stdscr.timeout(1000)

    while True:
        height, width = stdscr.getmaxyx()
        list_width = max(width * 35 // 100, 20)
        preview_start = list_width + 2
        preview_width = width - preview_start - 1
        help_row = height - 1
        tree_height = help_row

        # Keep selection visible
        sel_tree_idx = sel_indices[selected]
        if sel_tree_idx < scroll_offset:
            scroll_offset = sel_tree_idx
        if sel_tree_idx >= scroll_offset + tree_height:
            scroll_offset = sel_tree_idx - tree_height + 1

        # Find session header for current selection
        session_header_idx = None
        for look_back in range(sel_tree_idx, -1, -1):
            if items[look_back].kind == "session":
                session_header_idx = look_back
                break

        # Sticky header when session header is scrolled off the top
        sticky_header = None
        if session_header_idx is not None and session_header_idx < scroll_offset:
            sticky_header = items[session_header_idx]

        # Capture preview
        sel_window = items[sel_indices[selected]].window
        if sel_window:
            if sel_window.pane_id != last_pane_id:
                last_pane_id = sel_window.pane_id
                preview_cache = capture_pane(sel_window.pane_id)

        stdscr.erase()

        # Draw sticky session header if needed
        tree_start_row = 0
        if sticky_header:
            safe_addstr(
                stdscr, 0, 0, f" {sticky_header.label}",
                list_width, curses.color_pair(1) | curses.A_BOLD | curses.A_UNDERLINE,
            )
            tree_start_row = 1

        # Draw tree
        name_col = 2  # column where window names start (after "a ")
        for row in range(tree_start_row, tree_height):
            tree_idx = scroll_offset + (row - tree_start_row)
            if tree_idx >= len(items):
                break
            item = items[tree_idx]
            if item.kind == "session":
                safe_addstr(
                    stdscr, row, 0, item.label,
                    list_width, curses.color_pair(1) | curses.A_BOLD,
                )
            else:
                # Dim hotkey letter
                if item.hotkey:
                    safe_addstr(
                        stdscr, row, 0, item.hotkey,
                        1, curses.color_pair(5) | curses.A_BOLD,
                    )
                # Window name + emoji
                is_sel = tree_idx == sel_indices[selected]
                attr = curses.color_pair(2) if is_sel else curses.color_pair(3)
                safe_addstr(stdscr, row, name_col, item.label, list_width - name_col, attr)

        # Draw separator
        for row in range(tree_height):
            try:
                stdscr.addch(row, list_width, curses.ACS_VLINE, curses.color_pair(1))
            except curses.error:
                pass

        # Draw help bar
        safe_addstr(
            stdscr, help_row, 0,
            " a-z:jump  j/k:nav  del:kill  /:search  q:quit",
            width, curses.color_pair(4) | curses.A_DIM,
        )

        # Force full clear+redraw — raw ANSI preview writes desync
        # curses' attribute tracking, so differential SGR updates break.
        # clearok forces a screen clear before refresh, resetting state.
        stdscr.clearok(True)
        stdscr.refresh()

        # Draw preview — raw ANSI bypasses curses for pixel-perfect colors
        render_preview(sel_window, preview_cache,
                       preview_start, preview_width, tree_height)

        # Input
        key = stdscr.getch()

        if key == -1:
            # Timeout — refresh preview for live updates
            if sel_window:
                preview_cache = capture_pane(sel_window.pane_id)
            continue

        if key in (ord("j"), curses.KEY_DOWN):
            if selected < len(sel_indices) - 1:
                selected += 1
                last_pane_id = None

        elif key in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1
                last_pane_id = None

        elif key in (curses.KEY_DC, curses.KEY_BACKSPACE, 127):
            if sel_indices:
                window = items[sel_indices[selected]].window
                if window and _confirm_kill_window(stdscr, window, help_row, width):
                    sessions = get_windows()
                    if not sessions:
                        return
                    items, hotkey_map = build_tree(sessions)
                    sel_indices = selectable_indices(items)
                    if not sel_indices:
                        return
                    if selected >= len(sel_indices):
                        selected = max(0, len(sel_indices) - 1)
                    scroll_offset = 0
                    last_pane_id = None
                    preview_cache = []

        elif key in (ord("\n"), ord("\r")):
            window = items[sel_indices[selected]].window
            if window:
                switch_to_window(window)
            return

        elif key == ord("/"):
            curses.endwin()
            result = fzf_search(items)
            if result:
                switch_to_window(result)
                return
            # Restore curses
            stdscr.refresh()
            last_pane_id = None

        elif key == ord("q"):
            return

        elif key == 27:  # Esc or Alt+key
            alt = _read_alt_key(stdscr)
            if alt and _handle_alt_switch(stdscr, alt, "e"):
                return
            return  # bare Esc = quit

        elif 0x20 <= key <= 0x7E:
            ch = chr(key)
            if ch in hotkey_map:
                switch_to_window(hotkey_map[ch])
                return


# ── Session-focused UI ───────────────────────────────────────────


def session_ui(stdscr, start_session: str | None = None) -> None:
    """Session-focused window browser with h/l to cycle sessions."""
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)       # session header
    curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)  # selected
    curses.init_pair(3, curses.COLOR_WHITE, -1)      # normal window
    curses.init_pair(4, curses.COLOR_YELLOW, -1)     # help bar
    curses.init_pair(5, curses.COLOR_MAGENTA, -1)    # hotkey letter

    sessions = get_windows()
    if not sessions:
        return

    session_names = list(sessions.keys())
    if not session_names:
        return

    # Start on the specified or current session
    if start_session:
        target_session = start_session
    else:
        current_target = get_current_target()
        target_session = current_target.split(":")[0] if ":" in current_target else ""
    session_idx = 0
    for i, name in enumerate(session_names):
        if name == target_session:
            session_idx = i
            break

    selected = 0
    items: list[TreeItem] = []
    sel_indices: list[int] = []
    hotkey_map: dict[str, Window] = {}

    def rebuild() -> None:
        nonlocal items, sel_indices, selected, hotkey_map
        items, hotkey_map = build_session_tree(sessions[session_names[session_idx]])
        sel_indices = selectable_indices(items)
        selected = 0
        for i, idx in enumerate(sel_indices):
            w = items[idx].window
            if w and w.is_current:
                selected = i
                break

    rebuild()
    if not sel_indices:
        return

    scroll_offset = 0
    last_pane_id: str | None = None
    preview_cache: list[str] = []

    stdscr.timeout(1000)

    while True:
        height, width = stdscr.getmaxyx()
        list_width = max(width * 35 // 100, 20)
        preview_start = list_width + 2
        preview_width = width - preview_start - 1
        help_row = height - 1
        tree_start = 1  # row 0 is the session header
        tree_height = help_row - tree_start
        name_col = 2  # column where window names start (after hotkey)

        # Keep selection visible
        if sel_indices:
            sel_tree_idx = sel_indices[selected]
            if sel_tree_idx < scroll_offset:
                scroll_offset = sel_tree_idx
            if sel_tree_idx >= scroll_offset + tree_height:
                scroll_offset = sel_tree_idx - tree_height + 1

        # Capture preview
        sel_window = items[sel_indices[selected]].window if sel_indices else None
        if sel_window:
            if sel_window.pane_id != last_pane_id:
                last_pane_id = sel_window.pane_id
                preview_cache = capture_pane(sel_window.pane_id)

        stdscr.erase()

        # Session header with navigation arrows
        name = session_names[session_idx]
        n = len(session_names)
        header = f"\u25c0 {name} \u25b6  ({session_idx + 1}/{n})"
        safe_addstr(stdscr, 0, 0, header, list_width,
                    curses.color_pair(1) | curses.A_BOLD)

        # Window list — matches main UI layout: dim hotkey at col 0, name at col 2
        for row in range(tree_height):
            item_idx = scroll_offset + row
            if item_idx >= len(items):
                break
            item = items[item_idx]
            # Dim hotkey letter
            if item.hotkey:
                safe_addstr(
                    stdscr, tree_start + row, 0, item.hotkey,
                    1, curses.color_pair(5) | curses.A_BOLD,
                )
            # Window name + emoji
            is_sel = sel_indices and item_idx == sel_indices[selected]
            attr = curses.color_pair(2) if is_sel else curses.color_pair(3)
            safe_addstr(stdscr, tree_start + row, name_col, item.label,
                        list_width - name_col, attr)

        # Separator
        for row in range(help_row):
            try:
                stdscr.addch(row, list_width, curses.ACS_VLINE,
                             curses.color_pair(1))
            except curses.error:
                pass

        # Help bar
        safe_addstr(
            stdscr, help_row, 0,
            " a-z:jump  h/l:session  j/k:nav  n:new  del:kill  /:search  q:quit",
            width, curses.color_pair(4) | curses.A_DIM,
        )

        stdscr.clearok(True)
        stdscr.refresh()

        # Draw preview — full height (above help bar)
        render_preview(sel_window, preview_cache,
                       preview_start, preview_width, help_row)

        # Input
        key = stdscr.getch()

        if key == -1:
            if sel_window:
                preview_cache = capture_pane(sel_window.pane_id)
            continue

        if key in (ord("j"), curses.KEY_DOWN):
            if sel_indices and selected < len(sel_indices) - 1:
                selected += 1
                last_pane_id = None

        elif key in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1
                last_pane_id = None

        elif key in (curses.KEY_DC, curses.KEY_BACKSPACE, 127):
            if sel_indices:
                window = items[sel_indices[selected]].window
                if window and _confirm_kill_window(stdscr, window, help_row, width):
                    # Refresh window list
                    sessions = get_windows()
                    session_names = list(sessions.keys())
                    if not session_names:
                        return
                    # Stay on same session if it still exists
                    sess_name = window.session
                    if sess_name in session_names:
                        session_idx = session_names.index(sess_name)
                    elif session_idx >= len(session_names):
                        session_idx = len(session_names) - 1
                    scroll_offset = 0
                    last_pane_id = None
                    preview_cache = []
                    rebuild()

        elif key in (ord("l"), curses.KEY_RIGHT):
            # Next session
            session_idx = (session_idx + 1) % len(session_names)
            scroll_offset = 0
            last_pane_id = None
            rebuild()

        elif key in (ord("h"), curses.KEY_LEFT):
            # Previous session
            session_idx = (session_idx - 1) % len(session_names)
            scroll_offset = 0
            last_pane_id = None
            rebuild()

        elif key in (ord("\n"), ord("\r")):
            if sel_indices:
                window = items[sel_indices[selected]].window
                if window:
                    switch_to_window(window)
            return

        elif key == ord("n"):
            # Create a new window in the current session
            sess_name = session_names[session_idx]
            # Get the session's start directory so the new window opens there
            sp = subprocess.run(
                ["tmux", "display-message", "-t", f"={sess_name}:",
                 "-p", "#{session_path}"],
                capture_output=True, text=True, check=False,
            )
            start_dir = sp.stdout.strip()
            cmd = ["tmux", "new-window", "-d", "-t", f"={sess_name}:"]
            if start_dir:
                cmd += ["-c", start_dir]
            subprocess.run(cmd, capture_output=True, check=False)
            # Refresh window list
            sessions = get_windows()
            session_names = list(sessions.keys())
            if sess_name in session_names:
                session_idx = session_names.index(sess_name)
            scroll_offset = 0
            last_pane_id = None
            rebuild()

        elif key == ord("/"):
            curses.endwin()
            result = fzf_search(items)
            if result:
                switch_to_window(result)
                return
            stdscr.refresh()
            last_pane_id = None

        elif key == ord("q"):
            return

        elif key == 27:
            alt = _read_alt_key(stdscr)
            if alt and _handle_alt_switch(stdscr, alt, "w"):
                return
            return

        elif 0x20 <= key <= 0x7E:
            ch = chr(key)
            if ch in hotkey_map:
                switch_to_window(hotkey_map[ch])
                return


# ── AI-only (robots) UI ───────────────────────────────────────


def robots_ui(stdscr) -> None:
    """Like ui() but only shows AI windows across all sessions."""
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)       # session headers
    curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)  # selected
    curses.init_pair(3, curses.COLOR_WHITE, -1)      # normal window
    curses.init_pair(4, curses.COLOR_YELLOW, -1)     # help bar
    curses.init_pair(5, curses.COLOR_MAGENTA, -1)    # hotkey letter

    sessions = get_windows()
    if not sessions:
        return

    # Filter to AI windows only, drop empty sessions
    ai_sessions: dict[str, list[Window]] = {}
    for name, windows in sessions.items():
        ai_wins = [w for w in windows if is_ai_window(w)]
        if ai_wins:
            ai_sessions[name] = ai_wins

    if not ai_sessions:
        return

    items, hotkey_map = build_tree(ai_sessions)
    sel_indices = selectable_indices(items)
    if not sel_indices:
        return

    # Default to current window (if it's an AI window)
    selected = 0
    for i, idx in enumerate(sel_indices):
        w = items[idx].window
        if w and w.is_current:
            selected = i
            break

    scroll_offset = 0
    last_pane_id: str | None = None
    preview_cache: list[str] = []

    stdscr.timeout(1000)

    while True:
        height, width = stdscr.getmaxyx()
        list_width = max(width * 35 // 100, 20)
        preview_start = list_width + 2
        preview_width = width - preview_start - 1
        help_row = height - 1
        tree_height = help_row

        # Keep selection visible
        sel_tree_idx = sel_indices[selected]
        if sel_tree_idx < scroll_offset:
            scroll_offset = sel_tree_idx
        if sel_tree_idx >= scroll_offset + tree_height:
            scroll_offset = sel_tree_idx - tree_height + 1

        # Find session header for current selection
        session_header_idx = None
        for look_back in range(sel_tree_idx, -1, -1):
            if items[look_back].kind == "session":
                session_header_idx = look_back
                break

        # Sticky header when session header is scrolled off the top
        sticky_header = None
        if session_header_idx is not None and session_header_idx < scroll_offset:
            sticky_header = items[session_header_idx]

        # Capture preview
        sel_window = items[sel_indices[selected]].window
        if sel_window:
            if sel_window.pane_id != last_pane_id:
                last_pane_id = sel_window.pane_id
                preview_cache = capture_pane(sel_window.pane_id)

        stdscr.erase()

        # Draw sticky session header if needed
        tree_start_row = 0
        if sticky_header:
            safe_addstr(
                stdscr, 0, 0, f" {sticky_header.label}",
                list_width, curses.color_pair(1) | curses.A_BOLD | curses.A_UNDERLINE,
            )
            tree_start_row = 1

        # Draw tree
        name_col = 2
        for row in range(tree_start_row, tree_height):
            tree_idx = scroll_offset + (row - tree_start_row)
            if tree_idx >= len(items):
                break
            item = items[tree_idx]
            if item.kind == "session":
                safe_addstr(
                    stdscr, row, 0, item.label,
                    list_width, curses.color_pair(1) | curses.A_BOLD,
                )
            else:
                if item.hotkey:
                    safe_addstr(
                        stdscr, row, 0, item.hotkey,
                        1, curses.color_pair(5) | curses.A_BOLD,
                    )
                is_sel = tree_idx == sel_indices[selected]
                attr = curses.color_pair(2) if is_sel else curses.color_pair(3)
                safe_addstr(stdscr, row, name_col, item.label, list_width - name_col, attr)

        # Draw separator
        for row in range(tree_height):
            try:
                stdscr.addch(row, list_width, curses.ACS_VLINE, curses.color_pair(1))
            except curses.error:
                pass

        # Draw help bar
        safe_addstr(
            stdscr, help_row, 0,
            " a-z:jump  j/k:nav  del:kill  /:search  q:quit",
            width, curses.color_pair(4) | curses.A_DIM,
        )

        stdscr.clearok(True)
        stdscr.refresh()

        # Draw preview
        render_preview(sel_window, preview_cache,
                       preview_start, preview_width, tree_height)

        # Input
        key = stdscr.getch()

        if key == -1:
            # Timeout — refresh preview and re-scan for AI windows
            if sel_window:
                preview_cache = capture_pane(sel_window.pane_id)
            continue

        if key in (ord("j"), curses.KEY_DOWN):
            if selected < len(sel_indices) - 1:
                selected += 1
                last_pane_id = None

        elif key in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1
                last_pane_id = None

        elif key in (curses.KEY_DC, curses.KEY_BACKSPACE, 127):
            if sel_indices:
                window = items[sel_indices[selected]].window
                if window and _confirm_kill_window(stdscr, window, help_row, width):
                    # Re-scan AI windows
                    sessions = get_windows()
                    ai_sessions = {}
                    for sname, wins in sessions.items():
                        ai_wins = [w for w in wins if is_ai_window(w)]
                        if ai_wins:
                            ai_sessions[sname] = ai_wins
                    if not ai_sessions:
                        return
                    items, hotkey_map = build_tree(ai_sessions)
                    sel_indices = selectable_indices(items)
                    if not sel_indices:
                        return
                    if selected >= len(sel_indices):
                        selected = max(0, len(sel_indices) - 1)
                    scroll_offset = 0
                    last_pane_id = None
                    preview_cache = []

        elif key in (ord("\n"), ord("\r")):
            window = items[sel_indices[selected]].window
            if window:
                switch_to_window(window)
            return

        elif key == ord("/"):
            curses.endwin()
            result = fzf_search(items)
            if result:
                switch_to_window(result)
                return
            stdscr.refresh()
            last_pane_id = None

        elif key == ord("q"):
            return

        elif key == 27:
            alt = _read_alt_key(stdscr)
            if alt and _handle_alt_switch(stdscr, alt, "r"):
                return
            return

        elif 0x20 <= key <= 0x7E:
            ch = chr(key)
            if ch in hotkey_map:
                switch_to_window(hotkey_map[ch])
                return


# ── Worktree actions ──────────────────────────────────────────


def _delete_worktree(wt: Worktree) -> None:
    """Remove a worktree and delete its branch."""
    subprocess.run(
        ["git", "-C", str(wt.repo_root), "worktree", "remove", "--force", str(wt.path)],
        capture_output=True, check=False,
    )
    if wt.branch:
        subprocess.run(
            ["git", "-C", str(wt.repo_root), "branch", "-D", wt.branch],
            capture_output=True, check=False,
        )


def _open_agent_in_worktree(wt: Worktree, agent: str) -> None:
    """Open a new tmux window running an AI agent in the worktree."""
    ai_launch = str(Path.home() / ".tmux" / "scripts" / "ai-launch")
    window_name = f"{wt.display_name} ({agent})"
    runner_cmd = (
        f"python3 {shlex.quote(ai_launch)}"
        f" --agent {shlex.quote(agent)}"
        f" --no-worktree"
        f" --name {shlex.quote(wt.display_name)}"
    )
    tmux_cmd = f"bash -lc {shlex.quote(runner_cmd)}"
    subprocess.run(
        ["tmux", "new-window", "-n", window_name, "-c", str(wt.path), tmux_cmd],
        capture_output=True, check=False,
    )


def _open_shell_in_worktree(wt: Worktree) -> None:
    """Open a new tmux window with a shell in the worktree."""
    subprocess.run(
        ["tmux", "new-window", "-n", wt.display_name, "-c", str(wt.path)],
        capture_output=True, check=False,
    )


def _confirm_delete_worktree(stdscr, wt: Worktree, help_row: int, width: int) -> bool:
    """Show y/n confirmation for worktree deletion. Returns True if deleted."""
    dirty_warn = " (DIRTY)" if wt.status == "dirty" else ""
    prompt = f" Delete worktree '{wt.display_name}'{dirty_warn}? y/n"
    safe_addstr(stdscr, help_row, 0, prompt, width,
                curses.color_pair(4) | curses.A_BOLD)
    stdscr.clrtoeol()
    stdscr.clearok(True)
    stdscr.refresh()
    stdscr.timeout(-1)
    confirm_key = stdscr.getch()
    stdscr.timeout(1000)
    if confirm_key not in (ord("y"), ord("Y")):
        return False
    _delete_worktree(wt)
    return True


# ── Worktrees UI ─────────────────────────────────────────────


def worktrees_ui(stdscr) -> None:
    """Worktree cleanup browser showing all git worktrees."""
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)       # headers
    curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)  # selected
    curses.init_pair(3, curses.COLOR_WHITE, -1)      # normal
    curses.init_pair(4, curses.COLOR_YELLOW, -1)     # help bar / dirty
    curses.init_pair(5, curses.COLOR_MAGENTA, -1)    # hotkey letter
    curses.init_pair(6, curses.COLOR_RED, -1)        # prunable

    all_wt = get_worktrees()
    if not all_wt:
        # Show empty state
        height, width = stdscr.getmaxyx()
        safe_addstr(stdscr, 0, 1, "No worktrees found.", width - 1, curses.color_pair(3))
        safe_addstr(stdscr, height - 1, 0, " q:back", width,
                    curses.color_pair(4) | curses.A_DIM)
        stdscr.refresh()
        stdscr.timeout(-1)
        while True:
            key = stdscr.getch()
            if key in (ord("q"), 27):
                return

    selected = 0
    scroll_offset = 0
    stdscr.timeout(1000)

    while True:
        height, width = stdscr.getmaxyx()
        help_row = height - 1
        header_rows = 2  # header + separator
        list_height = help_row - header_rows

        # Column layout
        merged_col_w = 6   # "Merged"
        commit_col_w = 17  # "Last Commit"
        gap = 2
        name_col_start = 3  # after status char + space
        merged_col_start = width - merged_col_w - 1
        commit_col_start = merged_col_start - gap - commit_col_w
        name_col_w = max(commit_col_start - gap - name_col_start, 10)

        # Keep selection visible
        if selected < scroll_offset:
            scroll_offset = selected
        if selected >= scroll_offset + list_height:
            scroll_offset = selected - list_height + 1

        stdscr.erase()

        # Header row
        safe_addstr(stdscr, 0, name_col_start, "Name", name_col_w,
                    curses.color_pair(1) | curses.A_BOLD)
        safe_addstr(stdscr, 0, commit_col_start, "Last Commit", commit_col_w,
                    curses.color_pair(1) | curses.A_BOLD)
        safe_addstr(stdscr, 0, merged_col_start, "Merged", merged_col_w,
                    curses.color_pair(1) | curses.A_BOLD)

        # Separator row
        sep = "\u2500"
        safe_addstr(stdscr, 1, name_col_start, sep * name_col_w, name_col_w,
                    curses.color_pair(1))
        safe_addstr(stdscr, 1, commit_col_start, sep * commit_col_w, commit_col_w,
                    curses.color_pair(1))
        safe_addstr(stdscr, 1, merged_col_start, sep * merged_col_w, merged_col_w,
                    curses.color_pair(1))

        # Worktree rows
        for row in range(list_height):
            wt_idx = scroll_offset + row
            if wt_idx >= len(all_wt):
                break
            wt = all_wt[wt_idx]
            y = header_rows + row
            is_sel = (wt_idx == selected)

            # Status indicator
            if wt.status == "dirty":
                safe_addstr(stdscr, y, 1, "*", 1, curses.color_pair(4))
            elif wt.status == "prunable":
                safe_addstr(stdscr, y, 1, "~", 1, curses.color_pair(6))

            # Name
            name_attr = curses.color_pair(2) if is_sel else curses.color_pair(3)
            safe_addstr(stdscr, y, name_col_start, wt.display_name, name_col_w, name_attr)

            # Last commit
            commit_attr = curses.color_pair(2) if is_sel else curses.A_DIM
            safe_addstr(stdscr, y, commit_col_start, wt.last_commit_date, commit_col_w, commit_attr)

            # Merged
            merged_text = "yes" if wt.merged else "no"
            if is_sel:
                merged_attr = curses.color_pair(2)
            elif wt.merged:
                merged_attr = curses.A_DIM
            else:
                merged_attr = curses.color_pair(3) | curses.A_BOLD
            safe_addstr(stdscr, y, merged_col_start, merged_text, merged_col_w, merged_attr)

        # Help bar
        safe_addstr(
            stdscr, help_row, 0,
            " j/k:nav  del:delete  c:claude  x:codex  z:zsh  q:back",
            width, curses.color_pair(4) | curses.A_DIM,
        )

        stdscr.clearok(True)
        stdscr.refresh()

        # Input
        key = stdscr.getch()

        if key == -1:
            continue

        if key in (ord("j"), curses.KEY_DOWN):
            if selected < len(all_wt) - 1:
                selected += 1

        elif key in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1

        elif key in (curses.KEY_DC, curses.KEY_BACKSPACE, 127):
            if all_wt:
                if _confirm_delete_worktree(stdscr, all_wt[selected], help_row, width):
                    all_wt = get_worktrees()
                    if not all_wt:
                        return
                    if selected >= len(all_wt):
                        selected = max(0, len(all_wt) - 1)
                    scroll_offset = 0

        elif key == ord("c"):
            if all_wt:
                _open_agent_in_worktree(all_wt[selected], "claude")
                return

        elif key == ord("x"):
            if all_wt:
                _open_agent_in_worktree(all_wt[selected], "codex")
                return

        elif key == ord("z"):
            if all_wt:
                _open_shell_in_worktree(all_wt[selected])
                return

        elif key == ord("q"):
            return

        elif key == 27:
            alt = _read_alt_key(stdscr)
            if alt and _handle_alt_switch(stdscr, alt, "t"):
                return
            return


# ── New session creation ──────────────────────────────────────


FOLDER_MAX_DEPTH = 3
NEW_FOLDER_MARKER = "\u2726 New folder"


def _prompt_new_folder() -> str | None:
    """Prompt user for a new folder path and create it."""
    try:
        path_str = input("Enter path for new folder (relative to ~): ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if not path_str:
        return None
    path = Path(path_str).expanduser()
    if not path.is_absolute():
        path = Path.home() / path
    path.mkdir(parents=True, exist_ok=True)
    return str(path)


def _pick_folder() -> str | None:
    """Show fzf folder picker for new session creation."""
    home = str(Path.home())

    if shutil.which("fd"):
        find_cmd = (
            f"fd --type d --max-depth {FOLDER_MAX_DEPTH} "
            f"--exclude .git --exclude node_modules --exclude .cache "
            f"--exclude Library --exclude .Trash --exclude .worktrees "
            f"--exclude __pycache__ --exclude .venv --exclude venv "
            f"--exclude .npm --exclude .cargo --exclude .rustup "
            f". {shlex.quote(home)}"
        )
    else:
        find_cmd = (
            f"find {shlex.quote(home)} -maxdepth {FOLDER_MAX_DEPTH} "
            f"\\( -name .git -o -name node_modules -o -name .cache "
            f"-o -name Library -o -name .Trash -o -name .worktrees "
            f"-o -name __pycache__ -o -name .venv -o -name venv "
            f"-o -name .npm -o -name .cargo -o -name .rustup "
            f"\\) -prune -o -type d -print"
        )

    fzf_cmd = (
        f"(printf '%s\\n' {shlex.quote(NEW_FOLDER_MARKER)}; {find_cmd}) | fzf "
        f"--prompt 'folder> ' "
        f"--header 'Pick a folder for the new session' "
        f"--height 100% --layout reverse "
        f"--preview-window right:50%:wrap "
        f"--preview 'ls -la {{}} 2>/dev/null'"
    )

    output_path = None
    try:
        with tempfile.NamedTemporaryFile(
            mode="w", encoding="utf-8", prefix="wm-folder-out.", delete=False
        ) as outfile:
            output_path = Path(outfile.name)

        with output_path.open("w", encoding="utf-8") as stdout_fh:
            result = subprocess.run(
                ["bash", "-c", fzf_cmd],
                stdout=stdout_fh,
                check=False,
            )

        if result.returncode != 0:
            return None

        picked = output_path.read_text(encoding="utf-8").strip()
        if picked == NEW_FOLDER_MARKER:
            return _prompt_new_folder()
        return picked or None
    finally:
        if output_path is not None:
            output_path.unlink(missing_ok=True)


def _create_session(folder: str) -> str | None:
    """Create a new tmux session in the given folder and return its name."""
    path = Path(folder)
    session_name = path.name

    # Avoid name collision
    result = subprocess.run(
        ["tmux", "list-sessions", "-F", "#{session_name}"],
        capture_output=True, text=True, check=False,
    )
    existing = set(result.stdout.strip().splitlines()) if result.returncode == 0 else set()
    base_name = session_name
    counter = 1
    while session_name in existing:
        session_name = f"{base_name}-{counter}"
        counter += 1

    result = subprocess.run(
        ["tmux", "new-session", "-d", "-s", session_name, "-c", str(path)],
        capture_output=True, text=True, check=False,
    )
    return session_name if result.returncode == 0 else None


# ── Session list UI ───────────────────────────────────────────


def sessions_ui(stdscr) -> None:
    """Session list browser with window list preview."""
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)       # headers
    curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)  # selected
    curses.init_pair(3, curses.COLOR_WHITE, -1)      # normal
    curses.init_pair(4, curses.COLOR_YELLOW, -1)     # help bar
    curses.init_pair(5, curses.COLOR_MAGENTA, -1)    # hotkey letter

    all_sessions = get_sessions()
    if not all_sessions:
        return

    # Sessions use numbers 1-9, windows use letters
    win_pool = HOTKEY_POOL  # "abcdefghilmnoprstuvwxyz"
    session_hotkeys: dict[str, Session] = {}  # "1"-"9" -> Session
    for i, sess in enumerate(all_sessions):
        if i < 9:
            session_hotkeys[str(i + 1)] = sess

    # Pre-select current session
    selected = 0
    for i, sess in enumerate(all_sessions):
        if sess.is_current:
            selected = i
            break

    scroll_offset = 0
    stdscr.timeout(1000)

    while True:
        height, width = stdscr.getmaxyx()
        list_width = max(width * 50 // 100, 20)
        preview_start = list_width + 2
        preview_width = width - preview_start - 1
        help_row = height - 1
        list_height = help_row
        name_col = 2

        # Keep selection visible
        if selected < scroll_offset:
            scroll_offset = selected
        if selected >= scroll_offset + list_height:
            scroll_offset = selected - list_height + 1

        # Build window hotkey map for the highlighted session
        highlighted = all_sessions[selected]
        win_hotkeys: dict[str, Window] = {}
        for i, w in enumerate(highlighted.windows):
            if i < len(win_pool):
                win_hotkeys[win_pool[i]] = w

        stdscr.erase()

        # ── Left panel: session list ──
        for row in range(list_height):
            sess_idx = scroll_offset + row
            if sess_idx >= len(all_sessions):
                break
            sess = all_sessions[sess_idx]
            is_sel = (sess_idx == selected)

            # Hotkey number
            if sess_idx < 9:
                safe_addstr(
                    stdscr, row, 0, str(sess_idx + 1),
                    1, curses.color_pair(5) | curses.A_BOLD,
                )

            # Session name
            name_attr = curses.color_pair(2) if is_sel else curses.color_pair(3)
            safe_addstr(stdscr, row, name_col, sess.name, list_width - name_col, name_attr)

            # Working dir (dimmed) after the name
            path_display = _abbreviate_path(sess.path)
            name_end = name_col + len(sess.name) + 1
            remaining = list_width - name_end
            if remaining > 4:
                path_attr = curses.color_pair(2) | curses.A_DIM if is_sel else curses.A_DIM
                safe_addstr(stdscr, row, name_end, path_display, remaining, path_attr)

        # ── Separator ──
        for row in range(help_row):
            try:
                stdscr.addch(row, list_width, curses.ACS_VLINE, curses.color_pair(1))
            except curses.error:
                pass

        # ── Right panel: window list for highlighted session ──
        preview_row = 0
        for i, w in enumerate(highlighted.windows):
            if preview_row >= help_row:
                break
            emoji = ai_emoji(w)
            name = _clean_window_name(w.name)
            label = f"{emoji}{name}"
            # Hotkey letter
            hotkey = win_pool[i] if i < len(win_pool) else ""
            if hotkey:
                safe_addstr(
                    stdscr, preview_row, preview_start, hotkey,
                    1, curses.color_pair(5) | curses.A_BOLD,
                )
            safe_addstr(stdscr, preview_row, preview_start + 2, label, preview_width - 2, curses.color_pair(3))
            preview_row += 1

        # ── Help bar ──
        safe_addstr(
            stdscr, help_row, 0,
            " 1-9:session  a-z:window  j/k:nav  n:new  del:kill  t:worktrees  enter:switch  q:quit",
            width, curses.color_pair(4) | curses.A_DIM,
        )

        stdscr.clearok(True)
        stdscr.refresh()

        # Input
        key = stdscr.getch()

        if key == -1:
            # Timeout — refresh session data for live AI status updates
            all_sessions = get_sessions()
            session_hotkeys = {}
            for i, sess in enumerate(all_sessions):
                if i < 9:
                    session_hotkeys[str(i + 1)] = sess
            if selected >= len(all_sessions):
                selected = max(0, len(all_sessions) - 1)
            continue

        if key in (ord("j"), curses.KEY_DOWN):
            if selected < len(all_sessions) - 1:
                selected += 1

        elif key in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1

        elif key in (ord("\n"), ord("\r")):
            if all_sessions:
                session_ui(stdscr, start_session=all_sessions[selected].name)
            return

        elif key in (curses.KEY_DC, curses.KEY_BACKSPACE, 127):
            if all_sessions:
                target = all_sessions[selected]
                # Show confirmation on the help bar
                prompt = f" Kill session '{target.name}'? y/n"
                safe_addstr(stdscr, help_row, 0, prompt, width,
                            curses.color_pair(4) | curses.A_BOLD)
                stdscr.clrtoeol()
                stdscr.refresh()
                stdscr.timeout(-1)  # block until keypress
                confirm_key = stdscr.getch()
                stdscr.timeout(1000)
                if confirm_key in (ord("y"), ord("Y")):
                    # If killing the current session, switch away first
                    if target.is_current and len(all_sessions) > 1:
                        # Pick the next session, or previous if at the end
                        alt_idx = selected + 1 if selected + 1 < len(all_sessions) else selected - 1
                        switch_to_session(all_sessions[alt_idx].name)
                    subprocess.run(
                        ["tmux", "kill-session", "-t", target.name],
                        capture_output=True, check=False,
                    )
                    # Refresh session list
                    all_sessions = get_sessions()
                    if not all_sessions:
                        return
                    session_hotkeys = {}
                    for i, sess in enumerate(all_sessions):
                        if i < 9:
                            session_hotkeys[str(i + 1)] = sess
                    if selected >= len(all_sessions):
                        selected = max(0, len(all_sessions) - 1)

        elif key == ord("n"):
            curses.endwin()
            folder = _pick_folder()
            if folder:
                session_name = _create_session(folder)
                if session_name:
                    switch_to_session(session_name)
                    return
            # Cancelled — restore curses
            stdscr = curses.initscr()
            curses.noecho()
            curses.cbreak()
            stdscr.keypad(True)
            curses.curs_set(0)
            curses.use_default_colors()
            curses.init_pair(1, curses.COLOR_CYAN, -1)
            curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)
            curses.init_pair(3, curses.COLOR_WHITE, -1)
            curses.init_pair(4, curses.COLOR_YELLOW, -1)
            curses.init_pair(5, curses.COLOR_MAGENTA, -1)
            stdscr.timeout(1000)
            # Refresh session list
            all_sessions = get_sessions()
            session_hotkeys = {}
            for i, sess in enumerate(all_sessions):
                if i < 9:
                    session_hotkeys[str(i + 1)] = sess
            if selected >= len(all_sessions):
                selected = max(0, len(all_sessions) - 1)

        elif key == ord("t"):
            worktrees_ui(stdscr)
            return

        elif key == ord("q"):
            return

        elif key == 27:
            alt = _read_alt_key(stdscr)
            if alt and _handle_alt_switch(stdscr, alt, "s"):
                return
            return

        elif 0x20 <= key <= 0x7E:
            ch = chr(key)
            # Window hotkeys (letters) — switch directly
            if ch in win_hotkeys:
                switch_to_window(win_hotkeys[ch])
                return
            # Session hotkeys (numbers) — open session-focused view
            if ch in session_hotkeys:
                session_ui(stdscr, start_session=session_hotkeys[ch].name)
                return


def preview_mode(pane_id: str) -> None:
    """Output aligned preview for fzf's --preview command."""
    # Look up window name from pane for AI detection
    result = subprocess.run(
        ["tmux", "display-message", "-t", pane_id, "-p", "#{window_name}"],
        capture_output=True, text=True,
    )
    window_name = result.stdout.strip() if result.returncode == 0 else ""

    content = capture_pane(pane_id)
    if not content:
        return

    # Reuse the same alignment logic as the main view
    is_ai = "(claude)" in window_name.lower() or "(codex)" in window_name.lower()
    if is_ai:
        bottom = True
    else:
        leading_blank = 0
        for line in content:
            if not ANSI_SGR_RE.sub("", line).strip():
                leading_blank += 1
            else:
                break
        bottom = leading_blank > len(content) * 0.4

    lines = 50
    output = content[-lines:] if bottom else content[:lines]
    sys.stdout.write("\n".join(output) + "\n")


def main() -> None:
    ensure_reasonable_path()
    locale.setlocale(locale.LC_ALL, "")

    if len(sys.argv) >= 3 and sys.argv[1] == "--preview":
        preview_mode(sys.argv[2])
        return

    if "--worktrees" in sys.argv:
        curses.wrapper(worktrees_ui)
        return

    if "--robots" in sys.argv:
        curses.wrapper(robots_ui)
        return

    if "--sessions" in sys.argv:
        curses.wrapper(sessions_ui)
        return

    if "--session" in sys.argv:
        curses.wrapper(session_ui)
        return

    curses.wrapper(ui)


if __name__ == "__main__":
    main()
