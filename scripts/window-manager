#!/usr/bin/env python3
"""Custom tmux window manager with tree view and pane preview.

Shows sessions with windows nested underneath. Sessions are non-selectable
headers; j/k navigates only between windows. Preview panel on the right
shows the selected window's pane content with ANSI colors preserved.
Press / for fzf fuzzy search.
"""

from __future__ import annotations

import curses
import locale
import os
import re
import subprocess
import sys
import unicodedata
from dataclasses import dataclass


# ── Constants ────────────────────────────────────────────────────

DEFAULT_PATH_SEGMENTS = [
    "/opt/homebrew/bin",
    "/usr/local/bin",
    "/usr/bin",
    "/bin",
    "/usr/sbin",
    "/sbin",
]

# Predefined color pairs (1–4); dynamic pairs start at 5
_FIXED_PAIRS = 4
_color_pair_cache: dict[tuple[int, int], int] = {}
_next_pair_id = _FIXED_PAIRS + 1

ANSI_SGR_RE = re.compile(r"\033\[([0-9;]*)m")


def _rgb_to_256(r: int, g: int, b: int) -> int:
    """Map 24-bit RGB to the nearest xterm-256 color index."""
    # Grayscale shortcut
    if r == g == b:
        if r < 8:
            return 16
        if r > 248:
            return 231
        return round((r - 8) / 247 * 24) + 232
    # 6x6x6 color cube
    ri = round(r / 255 * 5)
    gi = round(g / 255 * 5)
    bi = round(b / 255 * 5)
    return 16 + 36 * ri + 6 * gi + bi


def _char_width(ch: str) -> int:
    """Approximate terminal display width of a character."""
    cp = ord(ch)
    if cp < 0x300:
        return 1
    eaw = unicodedata.east_asian_width(ch)
    if eaw in ("W", "F"):
        return 2
    # Emoji blocks that render as 2 cells in modern terminals
    if 0x1F000 <= cp <= 0x1FFFF or 0x2600 <= cp <= 0x27BF:
        return 2
    return 1


# ── Utilities ────────────────────────────────────────────────────


def ensure_reasonable_path() -> None:
    current = os.environ.get("PATH", "")
    parts = [p for p in current.split(":") if p]
    for seg in DEFAULT_PATH_SEGMENTS:
        if seg not in parts:
            parts.append(seg)
    os.environ["PATH"] = ":".join(parts)


# ── Data Model ───────────────────────────────────────────────────


@dataclass
class Window:
    session: str
    index: int
    name: str
    pane_id: str
    ai_status: str
    is_current: bool


@dataclass
class TreeItem:
    kind: str  # "session" or "window"
    label: str
    window: Window | None = None


# ── tmux helpers ─────────────────────────────────────────────────


def get_current_target() -> str:
    result = subprocess.run(
        ["tmux", "display-message", "-p", "#{session_name}:#{window_index}"],
        capture_output=True, text=True,
    )
    return result.stdout.strip() if result.returncode == 0 else ""


def get_windows() -> dict[str, list[Window]]:
    """Return windows grouped by session name (insertion-ordered)."""
    current = get_current_target()
    result = subprocess.run(
        [
            "tmux", "list-windows", "-a", "-F",
            "#{session_name}\t#{window_index}\t#{window_name}\t#{pane_id}\t#{@ai_status}",
        ],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return {}

    sessions: dict[str, list[Window]] = {}
    for line in result.stdout.strip().split("\n"):
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        session, idx, name, pane_id = parts[0], parts[1], parts[2], parts[3]
        ai_status = parts[4] if len(parts) > 4 else ""
        target = f"{session}:{idx}"
        w = Window(
            session=session,
            index=int(idx),
            name=name,
            pane_id=pane_id,
            ai_status=ai_status,
            is_current=(target == current),
        )
        sessions.setdefault(session, []).append(w)
    return sessions


def is_ai_window(window: Window) -> bool:
    name = window.name.lower()
    return "(claude)" in name or "(codex)" in name


def ai_emoji(window: Window) -> str:
    if not is_ai_window(window):
        return ""
    if window.ai_status == "active":
        return "\u26a1 "  # lightning
    if window.ai_status == "done":
        return "\u2705 "  # check
    return "\U0001f916 "  # robot


def capture_pane(pane_id: str) -> list[str]:
    """Capture visible pane content with ANSI colors, stripping trailing blanks."""
    result = subprocess.run(
        ["tmux", "capture-pane", "-e", "-t", pane_id, "-p"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        return ["(unable to capture pane)"]
    content = result.stdout.rstrip("\n").split("\n")
    # Strip trailing blank lines (ignoring escape codes)
    while content and not ANSI_SGR_RE.sub("", content[-1]).strip():
        content.pop()
    return content


def should_bottom_align(window: Window, content: list[str]) -> bool:
    """AI windows always bottom-align. Others bottom-align when the top is
    mostly blank (like a shell with a prompt at the bottom)."""
    if is_ai_window(window):
        return True
    if not content:
        return False
    leading_blank = 0
    for line in content:
        if not ANSI_SGR_RE.sub("", line).strip():
            leading_blank += 1
        else:
            break
    return leading_blank > len(content) * 0.4


def switch_to_window(window: Window) -> None:
    target = f"{window.session}:{window.index}"
    subprocess.run(["tmux", "select-window", "-t", target], check=False)
    subprocess.run(["tmux", "switch-client", "-t", window.session], check=False)


# ── Tree building ────────────────────────────────────────────────


def build_tree(sessions: dict[str, list[Window]]) -> list[TreeItem]:
    items: list[TreeItem] = []
    has_any_ai = any(is_ai_window(w) for ws in sessions.values() for w in ws)
    for session_name, windows in sessions.items():
        items.append(TreeItem(kind="session", label=session_name))
        for w in windows:
            emoji = ai_emoji(w)
            # Pad all non-AI windows globally so numbers align across sessions
            # Emoji = 2 display cells + 1 space = 3 display cells
            if has_any_ai and not emoji:
                emoji = "   "
            marker = "* " if w.is_current else "  "
            label = f"  {marker}{emoji}{w.index}: {w.name}"
            items.append(TreeItem(kind="window", label=label, window=w))
    return items


def selectable_indices(items: list[TreeItem]) -> list[int]:
    return [i for i, item in enumerate(items) if item.kind == "window"]


# ── fzf search ───────────────────────────────────────────────────


def fzf_search(items: list[TreeItem]) -> Window | None:
    windows = [it for it in items if it.kind == "window" and it.window]
    if not windows:
        return None

    fzf_lines = []
    for it in windows:
        w = it.window
        emoji = ai_emoji(w)
        fzf_lines.append(f"{w.session}:{w.index}\t{emoji}{w.name}")
    input_text = "\n".join(fzf_lines) + "\n"

    try:
        result = subprocess.run(
            [
                "fzf", "--reverse",
                "--header=Search windows",
                "--delimiter=\t", "--with-nth=1..",
            ],
            input=input_text, capture_output=True, text=True, check=False,
        )
    except FileNotFoundError:
        return None

    if result.returncode != 0 or not result.stdout.strip():
        return None

    key = result.stdout.strip().split("\t")[0]  # "session:index"
    for it in windows:
        w = it.window
        if f"{w.session}:{w.index}" == key:
            return w
    return None


# ── Curses rendering helpers ─────────────────────────────────────


def safe_addstr(win, y: int, x: int, text: str, max_width: int, attr: int = 0) -> None:
    """Render plain text (no ANSI) with exact column control."""
    if max_width <= 0:
        return
    height, width = win.getmaxyx()
    if y < 0 or y >= height or x >= width:
        return
    col = x
    max_col = min(x + max_width, width)
    for ch in text:
        if ch == "\t":
            spaces = 8 - ((col - x) % 8)
            for _ in range(min(spaces, max_col - col)):
                try:
                    win.addch(y, col, " ", attr)
                except curses.error:
                    return
                col += 1
        else:
            cw = _char_width(ch)
            if col + cw > max_col:
                break
            try:
                win.addch(y, col, ch, attr)
            except curses.error:
                return
            col += cw
    # Clear remaining columns
    while col < max_col:
        try:
            win.addch(y, col, " ", attr)
        except curses.error:
            return
        col += 1


def _get_color_pair(fg: int, bg: int) -> int:
    """Get or create a curses color pair for the given fg/bg."""
    global _next_pair_id
    key = (fg, bg)
    if key in _color_pair_cache:
        return _color_pair_cache[key]
    try:
        max_pairs = curses.COLOR_PAIRS
    except AttributeError:
        max_pairs = 256
    if _next_pair_id >= max_pairs:
        return 0
    curses.init_pair(_next_pair_id, fg, bg)
    _color_pair_cache[key] = _next_pair_id
    _next_pair_id += 1
    return _color_pair_cache[key]


def render_ansi_line(
    win, y: int, x: int, text: str, max_width: int,
) -> None:
    """Render a line containing ANSI SGR escape codes using curses colors."""
    height, width = win.getmaxyx()
    if y < 0 or y >= height or x >= width or max_width <= 0:
        return
    max_col = min(x + max_width, width)
    col = x
    fg, bg = -1, -1
    bold = dim = italic = underline = reverse = False

    pos = 0
    while pos < len(text) and col < max_col:
        m = ANSI_SGR_RE.match(text, pos)
        if m:
            params_str = m.group(1)
            params = params_str.split(";") if params_str else ["0"]
            i = 0
            while i < len(params):
                try:
                    p = int(params[i])
                except ValueError:
                    i += 1
                    continue
                if p == 0:
                    fg, bg = -1, -1
                    bold = dim = italic = underline = reverse = False
                elif p == 1:
                    bold = True
                elif p == 2:
                    dim = True
                elif p == 3:
                    italic = True
                elif p == 4:
                    underline = True
                elif p == 7:
                    reverse = True
                elif p == 22:
                    bold = dim = False
                elif p == 23:
                    italic = False
                elif p == 24:
                    underline = False
                elif p == 27:
                    reverse = False
                elif 30 <= p <= 37:
                    fg = p - 30
                elif 40 <= p <= 47:
                    bg = p - 40
                elif 90 <= p <= 97:
                    fg = p - 82  # maps to curses colors 8–15
                elif 100 <= p <= 107:
                    bg = p - 92
                elif p == 38 and i + 1 < len(params):
                    try:
                        mode = int(params[i + 1])
                        if mode == 5 and i + 2 < len(params):
                            fg = int(params[i + 2])
                            i += 2
                        elif mode == 2 and i + 4 < len(params):
                            r = int(params[i + 2])
                            g = int(params[i + 3])
                            b = int(params[i + 4])
                            fg = _rgb_to_256(r, g, b)
                            i += 4
                    except ValueError:
                        pass
                elif p == 48 and i + 1 < len(params):
                    try:
                        mode = int(params[i + 1])
                        if mode == 5 and i + 2 < len(params):
                            bg = int(params[i + 2])
                            i += 2
                        elif mode == 2 and i + 4 < len(params):
                            r = int(params[i + 2])
                            g = int(params[i + 3])
                            b = int(params[i + 4])
                            bg = _rgb_to_256(r, g, b)
                            i += 4
                    except ValueError:
                        pass
                elif p == 39:
                    fg = -1
                elif p == 49:
                    bg = -1
                i += 1
            pos = m.end()
            continue

        # Skip other escape sequences (cursor movement, etc.)
        if text[pos] == "\033":
            end = pos + 1
            while end < len(text) and text[end] not in "ABCDEFGHJKSTfmnsulh":
                end += 1
            pos = end + 1 if end < len(text) else end
            continue

        ch = text[pos]
        pos += 1

        if ch == "\t":
            spaces = 8 - ((col - x) % 8)
            for _ in range(min(spaces, max_col - col)):
                try:
                    win.addch(y, col, " ")
                except curses.error:
                    return
                col += 1
            continue

        cw = _char_width(ch)
        if col + cw > max_col:
            break
        attr = 0
        pair_id = _get_color_pair(fg, bg)
        if pair_id:
            attr = curses.color_pair(pair_id)
        if bold:
            attr |= curses.A_BOLD
        if dim:
            attr |= curses.A_DIM
        if underline:
            attr |= curses.A_UNDERLINE
        if reverse:
            attr |= curses.A_REVERSE
        if italic:
            attr |= getattr(curses, "A_ITALIC", 0)
        try:
            win.addch(y, col, ch, attr)
        except curses.error:
            return
        col += cw

    # Clear remaining columns
    while col < max_col:
        try:
            win.addch(y, col, " ")
        except curses.error:
            return
        col += 1


# ── Main UI ──────────────────────────────────────────────────────


def ui(stdscr) -> None:
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN, -1)
    curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)
    curses.init_pair(3, curses.COLOR_WHITE, -1)
    curses.init_pair(4, curses.COLOR_YELLOW, -1)

    sessions = get_windows()
    if not sessions:
        return

    items = build_tree(sessions)
    sel_indices = selectable_indices(items)
    if not sel_indices:
        return

    # Default to current window
    selected = 0
    for i, idx in enumerate(sel_indices):
        w = items[idx].window
        if w and w.is_current:
            selected = i
            break

    scroll_offset = 0
    last_pane_id: str | None = None
    preview_cache: list[str] = []

    # 1000ms timeout: keys are instant, preview refreshes every ~1s when idle
    stdscr.timeout(1000)

    while True:
        height, width = stdscr.getmaxyx()
        list_width = max(width * 35 // 100, 20)
        preview_start = list_width + 2
        preview_width = width - preview_start - 1
        help_row = height - 1
        tree_height = help_row

        # Keep selection visible
        sel_tree_idx = sel_indices[selected]
        if sel_tree_idx < scroll_offset:
            scroll_offset = sel_tree_idx
        if sel_tree_idx >= scroll_offset + tree_height:
            scroll_offset = sel_tree_idx - tree_height + 1

        # Find session header for current selection
        session_header_idx = None
        for look_back in range(sel_tree_idx, -1, -1):
            if items[look_back].kind == "session":
                session_header_idx = look_back
                break

        # Sticky header when session header is scrolled off the top
        sticky_header = None
        if session_header_idx is not None and session_header_idx < scroll_offset:
            sticky_header = items[session_header_idx]

        # Capture preview
        sel_window = items[sel_indices[selected]].window
        if sel_window:
            if sel_window.pane_id != last_pane_id:
                last_pane_id = sel_window.pane_id
                preview_cache = capture_pane(sel_window.pane_id)

        stdscr.erase()

        # Draw sticky session header if needed
        tree_start_row = 0
        if sticky_header:
            safe_addstr(
                stdscr, 0, 0, f" {sticky_header.label}",
                list_width, curses.color_pair(1) | curses.A_BOLD | curses.A_UNDERLINE,
            )
            tree_start_row = 1

        # Draw tree
        for row in range(tree_start_row, tree_height):
            tree_idx = scroll_offset + (row - tree_start_row)
            if tree_idx >= len(items):
                break
            item = items[tree_idx]
            if item.kind == "session":
                safe_addstr(
                    stdscr, row, 0, f" {item.label}",
                    list_width, curses.color_pair(1) | curses.A_BOLD,
                )
            else:
                is_sel = tree_idx == sel_indices[selected]
                attr = curses.color_pair(2) if is_sel else curses.color_pair(3)
                safe_addstr(stdscr, row, 0, item.label, list_width, attr)

        # Draw separator
        for row in range(tree_height):
            try:
                stdscr.addch(row, list_width, curses.ACS_VLINE, curses.color_pair(1))
            except curses.error:
                pass

        # Draw preview (alignment depends on window type and content)
        if preview_width > 0 and preview_cache and sel_window:
            if should_bottom_align(sel_window, preview_cache):
                visible = preview_cache[-tree_height:]
                start_row = max(0, tree_height - len(visible))
            else:
                visible = preview_cache[:tree_height]
                start_row = 0
            for i, line in enumerate(visible):
                row = start_row + i
                if row >= tree_height:
                    break
                render_ansi_line(stdscr, row, preview_start, line, preview_width)

        # Draw help bar
        safe_addstr(
            stdscr, help_row, 0,
            " j/k:nav  Enter:switch  /:search  q:quit",
            width, curses.color_pair(4) | curses.A_DIM,
        )

        stdscr.refresh()

        # Input
        key = stdscr.getch()

        if key == -1:
            # Timeout — refresh preview for live updates
            if sel_window:
                preview_cache = capture_pane(sel_window.pane_id)
            continue

        if key in (ord("j"), curses.KEY_DOWN):
            if selected < len(sel_indices) - 1:
                selected += 1
                last_pane_id = None

        elif key in (ord("k"), curses.KEY_UP):
            if selected > 0:
                selected -= 1
                last_pane_id = None

        elif key in (ord("\n"), ord("\r")):
            window = items[sel_indices[selected]].window
            if window:
                switch_to_window(window)
            return

        elif key == ord("/"):
            curses.endwin()
            result = fzf_search(items)
            if result:
                switch_to_window(result)
                return
            # Restore curses
            stdscr.refresh()
            last_pane_id = None

        elif key in (ord("q"), 27):  # q or Esc
            return


def main() -> None:
    ensure_reasonable_path()
    locale.setlocale(locale.LC_ALL, "")
    curses.wrapper(ui)


if __name__ == "__main__":
    main()
