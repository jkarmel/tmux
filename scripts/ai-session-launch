#!/usr/bin/env python3
"""AI session launcher for tmux.

Presents a session picker (existing sessions + new session option),
then launches the AI agent popup in the chosen session.
"""

from __future__ import annotations

import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path


# ── Constants ────────────────────────────────────────────────────

NEW_SESSION_MARKER = "\u2726 New session"
THIS_SESSION_PREFIX = "\u25cf This session"
DEFAULT_PATH_SEGMENTS = [
    "/opt/homebrew/bin",
    "/usr/local/bin",
    "/usr/bin",
    "/bin",
    "/usr/sbin",
    "/sbin",
]
AI_POPUP = Path.home() / ".tmux" / "scripts" / "ai-popup"
FOLDER_MAX_DEPTH = 3


# ── Shared Utilities ─────────────────────────────────────────────


def pause_for_popup() -> None:
    try:
        input("Press Enter to close...")
    except EOFError:
        pass


def die(message: str, *, exit_code: int = 1) -> None:
    print(f"ERROR: {message}", file=sys.stderr)
    pause_for_popup()
    raise SystemExit(exit_code)


def ensure_reasonable_path() -> None:
    current = os.environ.get("PATH", "")
    parts = [part for part in current.split(":") if part]
    for segment in DEFAULT_PATH_SEGMENTS:
        if segment not in parts:
            parts.append(segment)
    os.environ["PATH"] = ":".join(parts)


def require_dependency(command: str) -> None:
    if shutil.which(command) is None:
        raise RuntimeError(f"'{command}' is required but not found in PATH")


def run_command(
    command: list[str], *, cwd: Path | None = None
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        command, capture_output=True, text=True, check=False, cwd=cwd
    )


# ── FZF Helper ──────────────────────────────────────────────────


def fzf_pick(
    items: list[str],
    *,
    prompt: str = "> ",
    header: str | None = None,
    preview: str | None = None,
) -> str | None:
    input_path: Path | None = None
    output_path: Path | None = None
    try:
        with tempfile.NamedTemporaryFile(
            mode="w", encoding="utf-8", prefix="ai-session-in.", delete=False
        ) as infile:
            infile.write("\n".join(items))
            infile.write("\n")
            input_path = Path(infile.name)

        with tempfile.NamedTemporaryFile(
            mode="w", encoding="utf-8", prefix="ai-session-out.", delete=False
        ) as outfile:
            output_path = Path(outfile.name)

        cmd = [
            "fzf",
            "--prompt", prompt,
            "--height", "100%",
            "--layout", "reverse",
            "--ansi",
        ]
        if header:
            cmd.extend(["--header", header])
        if preview:
            cmd.extend(["--preview-window", "right:50%:wrap", "--preview", preview])

        with input_path.open("r", encoding="utf-8") as stdin_fh, \
             output_path.open("w", encoding="utf-8") as stdout_fh:
            result = subprocess.run(
                cmd, stdin=stdin_fh, stdout=stdout_fh, check=False,
            )

        if result.returncode != 0:
            return None

        picked = output_path.read_text(encoding="utf-8").strip()
        return picked or None
    finally:
        if input_path is not None:
            input_path.unlink(missing_ok=True)
        if output_path is not None:
            output_path.unlink(missing_ok=True)


# ── Session Discovery ───────────────────────────────────────────


def list_sessions() -> list[dict]:
    result = run_command([
        "tmux", "list-sessions", "-F",
        "#{session_name}\t#{session_path}\t#{session_windows}\t#{session_attached}"
    ])
    if result.returncode != 0:
        return []

    sessions = []
    for line in result.stdout.strip().splitlines():
        if not line.strip():
            continue
        parts = line.split("\t")
        if len(parts) >= 4:
            sessions.append({
                "name": parts[0],
                "path": parts[1],
                "windows": parts[2],
                "attached": parts[3] == "1",
            })
    return sessions


def format_session_line(session: dict) -> str:
    folder = Path(session["path"]).name
    dim = "\033[2m"
    reset = "\033[0m"
    return f"{session['name']}  {dim}/{folder}{reset}"


# ── Steps ────────────────────────────────────────────────────────


def get_current_session() -> str:
    result = run_command(["tmux", "display-message", "-p", "#{session_name}"])
    return result.stdout.strip()


def step_pick_session(sessions: list[dict], current: str) -> str | None:
    """Show fzf session picker. Returns session name or NEW_SESSION_MARKER."""
    this_session_label = f"{THIS_SESSION_PREFIX} ({current})"

    items = [this_session_label, NEW_SESSION_MARKER]
    for s in sessions:
        if s["name"] == current:
            continue
        items.append(format_session_line(s))

    # Preview: show only AI (robot) windows with activity status
    ai_preview_fn = "\n".join([
        "show_ai() {",
        "  local out=$(tmux list-windows -t \"$1\" -F '#{window_name}|#{@ai_status}' 2>/dev/null \\",
        "    | grep -E '\\(claude\\)|\\(codex\\)' \\",
        "    | while IFS='|' read -r wname aist; do",
        "        case \"$aist\" in",
        "          (active) printf '  ⚡ %s\\n' \"$wname\";;",
        "          (\"done\") printf '  ✅ %s\\n' \"$wname\";;",
        "          (idle) printf '  🤖 %s\\n' \"$wname\";;",
        "          (*) printf '  🤖 %s\\n' \"$wname\";;",
        "        esac",
        "      done)",
        "  if [ -z \"$out\" ]; then echo '  No AI windows'; else echo \"$out\"; fi",
        "}",
        "",
    ])
    preview_cmd = "\n".join([
        ai_preview_fn,
        "if echo {} | grep -q '^\\xE2\\x9C\\xA6'; then",
        "  echo 'Create a new tmux session in a folder of your choice'",
        "elif echo {} | grep -q '^\\xE2\\x97\\x8F'; then",
        f"  show_ai {shlex_quote(current)}",
        "else",
        "  name=$(echo {} | sed \"s/ .*//\")",
        "  show_ai \"$name\"",
        "fi",
    ])

    picked = fzf_pick(
        items,
        prompt="session> ",
        header="Pick a session for AI agent (or start new)",
        preview=preview_cmd,
    )

    if picked is None:
        return None
    if picked == NEW_SESSION_MARKER:
        return NEW_SESSION_MARKER
    if picked == this_session_label:
        return current

    # Extract session name (first field, before spaces)
    session_name = picked.split()[0]
    return session_name


def step_pick_folder() -> str | None:
    """Show fzf folder picker for new session."""
    home = str(Path.home())

    if shutil.which("fd"):
        find_cmd = (
            f"fd --type d --max-depth {FOLDER_MAX_DEPTH} "
            f"--exclude .git --exclude node_modules --exclude .cache "
            f"--exclude Library --exclude .Trash --exclude .worktrees "
            f"--exclude __pycache__ --exclude .venv --exclude venv "
            f"--exclude .npm --exclude .cargo --exclude .rustup "
            f". {shlex_quote(home)}"
        )
    else:
        find_cmd = (
            f"find {shlex_quote(home)} -maxdepth {FOLDER_MAX_DEPTH} "
            f"\\( -name .git -o -name node_modules -o -name .cache "
            f"-o -name Library -o -name .Trash -o -name .worktrees "
            f"-o -name __pycache__ -o -name .venv -o -name venv "
            f"-o -name .npm -o -name .cargo -o -name .rustup "
            f"\\) -prune -o -type d -print"
        )

    preview_cmd = "ls -la {} 2>/dev/null"

    output_path = None
    try:
        with tempfile.NamedTemporaryFile(
            mode="w", encoding="utf-8", prefix="ai-folder-out.", delete=False
        ) as outfile:
            output_path = Path(outfile.name)

        fzf_cmd = (
            f"{find_cmd} | fzf "
            f"--prompt 'folder> ' "
            f"--header 'Pick a folder for the new session' "
            f"--height 100% --layout reverse "
            f"--preview-window right:50%:wrap "
            f"--preview \"{preview_cmd}\""
        )

        with output_path.open("w", encoding="utf-8") as stdout_fh:
            result = subprocess.run(
                ["bash", "-c", fzf_cmd],
                stdout=stdout_fh,
                check=False,
            )

        if result.returncode != 0:
            return None

        picked = output_path.read_text(encoding="utf-8").strip()
        return picked or None
    finally:
        if output_path is not None:
            output_path.unlink(missing_ok=True)


def shlex_quote(s: str) -> str:
    """Shell-quote a string."""
    import shlex
    return shlex.quote(s)


def create_new_session(folder: str) -> str | None:
    """Create a new tmux session in the given folder and return its name."""
    path = Path(folder)
    session_name = path.name

    # Avoid name collision with existing sessions
    existing = {s["name"] for s in list_sessions()}
    base_name = session_name
    counter = 1
    while session_name in existing:
        session_name = f"{base_name}-{counter}"
        counter += 1

    result = run_command([
        "tmux", "new-session", "-d", "-s", session_name, "-c", str(path)
    ])
    if result.returncode != 0:
        details = (result.stderr or result.stdout).strip()
        die(f"Failed to create session: {details}")

    return session_name


# ── Main ─────────────────────────────────────────────────────────


def main() -> int:
    try:
        ensure_reasonable_path()
        require_dependency("tmux")
        require_dependency("fzf")

        if not AI_POPUP.is_file():
            die(f"Missing ai-popup script: {AI_POPUP}")

        # Step 1: pick session
        current = get_current_session()
        sessions = list_sessions()
        picked = step_pick_session(sessions, current)

        if picked is None:
            return 0

        if picked == NEW_SESSION_MARKER:
            # Step 2: pick folder for new session
            folder = step_pick_folder()
            if folder is None:
                return 0

            session_name = create_new_session(folder)
            if session_name is None:
                return 0
        else:
            session_name = picked

        # Switch client to the chosen session
        run_command(["tmux", "switch-client", "-t", session_name])

        # Launch ai-popup (exec replaces this process)
        os.execvp("python3", ["python3", str(AI_POPUP)])

    except RuntimeError as exc:
        die(str(exc))
    except KeyboardInterrupt:
        return 0
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
